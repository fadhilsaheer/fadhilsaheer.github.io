---
import "../styles/global.css";

import Header from "../components/Header.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preload" as="image" href="/og.png" />
    <title>Fadhil Saheer — Developer & Builder</title>
    <meta
      name="description"
      content="I'm Fadhil Saheer — a full-stack developer building web and mobile applications. Explore my projects and tech journey."
    />
    <meta name="application-name" content="fadhilsaheer" />
    <meta name="author" content="Fadhil Saheer" />
    <meta
      name="keywords"
      content="Fadhil Saheer,developer,builder,portfolio,React Native,Next.js,TypeScript,web developer,mobile developer,software engineer,tech explorer"
    />
    <meta name="referrer" content="origin-when-cross-origin" />
    <meta name="creator" content="Fadhil Saheer" />
    <meta name="publisher" content="Fadhil Saheer" />
    <meta name="category" content="Technology" />
    <link rel="canonical" href="https://fadhilsaheer.tech" />
    <meta
      name="format-detection"
      content="telephone=no, address=no, email=no"
    />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="FADHIL" />
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content="black-translucent"
    />
    <meta property="og:title" content="Fadhil Saheer — Developer & Builder" />
    <meta
      property="og:description"
      content="I'm Fadhil Saheer — a full-stack developer building web and mobile applications. Explore my projects and tech journey."
    />
    <meta property="og:url" content="https://fadhilsaheer.tech" />
    <meta property="og:image" content="https://fadhilsaheer.tech/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Fadhil Saheer" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@fadhilsaheer" />
    <meta name="twitter:title" content="Fadhil Saheer — Developer & Builder" />
    <meta
      name="twitter:description"
      content="I'm Fadhil Saheer — a full-stack developer building web and mobile applications. Explore my projects and tech journey."
    />
    <meta name="twitter:image" content="https://fadhilsaheer.tech/og.png" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <meta name="theme-color" content="#181926" />
  </head>
  <body
    class="bg-macchiato-crust text-macchiato-text flex flex-col items-center py-10"
  >
    <Header />

    <div class="max-w-xl w-full px-5">
      <h1 class="text-2xl font-medium">Fadhil Saheer</h1>

      <img
        src="https://res.cloudinary.com/dvsipt8rv/image/upload/v1759453070/public/ash_yiqvxi.jpg"
        alt=""
        class="size-20 rounded-full"
      />

      <div class="p-5 mt-10 bg-macchiato-mantle hover:bg-macchiato-base">
        <h3>Hello World</h3>
        <p>
          Lorem ipsum dolor sit amet consectetur adipisicing elit. Autem quasi
          saepe minus fugit asperiores odit. Facere eaque commodi
          exercitationem, distinctio, ipsam, in alias aperiam ullam reiciendis
          voluptas natus suscipit neque.
        </p>
      </div>

      <div class="h-screen"></div>
    </div>
  </body>
</html>
